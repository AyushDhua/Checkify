{
  "manifest_version": 3,
  "name": "Checkify – Dark Pattern Detector",
  "version": "1.0.0",
  "description": "AI-powered dark pattern detector. Highlights manipulative UI patterns on any webpage in real time.",

  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": ["http://127.0.0.1:2910/*"],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Checkify – Dark Pattern Detector",
    "default_icon": "icons/icon.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/icon.png"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
